{
  "schemaVersion": 1,
  "id": "pxrp",
  "version": "${version}",
  "name": "PxRP",
  "description": "Lua-scriptable roleplay command framework for Fabric servers.",
  "authors": ["PyXiion"],
  "contact": {
    "PyXiion": "me@pyxiion.ru"
  },
  "license": "LGPL-3.0",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "adapter": "kotlin",
        "value": "ru.pyxiion.pxrp.PxRp"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric": "*",
    "minecraft": ">=1.21-",
    "fabric-language-kotlin": ">=1.10.8+kotlin.1.9.0"
  },
  "accessWidener" : "pxrp.accesswidener",
  "mixins": [
    "pxrp.mixins.json"
  ]
}
